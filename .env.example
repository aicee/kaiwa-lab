# Server-only. Used later for post-session feedback.
OPENAI_API_KEY=

# Server-only. Never expose this with a NEXT_PUBLIC_ prefix.
ELEVENLABS_API_KEY=

# Server-managed agent id. Keep it out of frontend code and NEXT_PUBLIC variables.
ELEVENLABS_AGENT_ID=

DEMO_ACCESS_CODE=

# Browser-safe app URL only. No ElevenLabs secret belongs in NEXT_PUBLIC variables.
NEXT_PUBLIC_APP_URL=http://localhost:3000
